rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && request.auth.token.admin == true;
    }
    
    // Example: Members collection with more specific rules
    match /members/{memberId} {
      // Public can submit membership applications (create only).
      allow create: if true;
      // Admin can read/write all member documents.
      allow read, update, delete: if isAdmin();
    }

    match /payments/{paymentId} {
      allow read, write: if isAdmin();
    }

    match /elections/{electionId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /nominations/{nominationId} {
      // Keep nominations admin-only for now.
      allow read, write: if isAdmin();
    }

    match /notifications/{notificationId} {
      allow read, write: if isAdmin();
    }
    
    // Example: Public collections (events, documents, etc.)
    match /events/{eventId} {
      allow read: if true; // Public read access
      allow write: if isAdmin();
    }

    match /leadership_executive/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /leadership_payam/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    match /documents/{documentId} {
      allow read: if true; // Public read access
      allow write: if isAdmin();
    }

    match /scholarships/{scholarshipId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /scholars/{scholarId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /testimonials/{testimonialId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /mentors/{mentorId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /partners/{partnerId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /contact_messages/{messageId} {
      allow create: if true; // Anyone can submit a contact message
      allow read, update, delete: if isAdmin(); // Only admins can view/manage
    }

    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }
  }
}




